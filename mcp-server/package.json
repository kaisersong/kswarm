{
  "name": "@kswarm/mcp-server",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "kswarm-mcp": "dist/server.bundle.js"
  },
  "scripts": {
    "build": "tsc",
    "build:bundle": "esbuild dist/server.js --bundle --platform=node --format=esm --outfile=dist/server.bundle.js --packages=bundle --external:node:*",
    "dev": "tsx src/server.ts",
    "test": "node --test tests/*.test.ts --loader tsx"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ws": "^8.20.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
